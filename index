async function loadLB(){$('lbl').innerHTML='<p style="padding:14px;color:var(--sub)">Loading...</p>';const testId=$('lbf').value||'';try{const ts=await db.collection('tests').get();const sel=$('lbf');const ex=new Set(Array.from(sel.options).map(o=>o.value));if(!ex.has('')){const o=document.createElement('option');o.value='';o.textContent='All Tests';sel.insertBefore(o,sel.firstChild)}ts.docs.forEach(d=>{if(!ex.has(d.id)){const o=document.createElement('option');o.value=d.id;o.textContent=d.data().title||d.id;sel.appendChild(o)}})}catch(e){}if(S.lbMode==='t'){renderTeamsLB(testId);return}try{let q=db.collection('results').orderBy('wpm','desc');if(testId)q=db.collection('results').where('testId','==',testId).orderBy('wpm','desc');const sn=await q.get();const seen=new Map();sn.docs.filter(d=>d.data().status!=='abandoned').forEach(d=>{const r=d.data();const k=r.learnerId+(testId?'':r.testId);if(!seen.has(k)||seen.get(k).wpm<r.wpm)seen.set(k,r)});renderLbRows([...seen.values()].sort((a,b)=>b.wpm-a.wpm))}catch(e){$('lbl').innerHTML='<p style="padding:14px;color:var(--bad)">Error.</p>'}}
function renderLbRows(rows){if(!rows.length){$('lbl').innerHTML='<p style="padding:14px;color:var(--sub)">No results yet — be the first!</p>';return}$('lbl').innerHTML=rows.map((r,i)=>{const rc=i===0?'g':i===1?'s':i===2?'b':'';const m=i===0?'🥇':i===1?'🥈':i===2?'🥉':'';const L=lvlInfo(r.level||'beginner');return`<div class="lbr"><div class="lbrk ${rc}">${m||'#'+(i+1)}</div><div style="flex:1;font-weight:600">${r.learnerName||'?'}</div><div style="flex:1;font-size:.78rem;color:var(--sub)">${r.testTitle||''}</div><span class="lvl lvl-${L.cls}">${L.emoji}</span><div style="font-family:monospace;font-weight:700;font-size:1rem;margin-left:7px">${r.wpm}</div><div style="margin-left:7px;color:var(--sub);font-size:.83rem">${ga(r)}%</div></div>`}).join('')}
async function renderTeamsLB(testId){try{let q=db.collection('results').orderBy('wpm','desc');if(testId)q=db.collection('results').where('testId','==',testId).orderBy('wpm','desc');const[rs,ls,tms]=await Promise.all([q.get(),db.collection('learners').get(),db.collection('teams').get()]);const lt={};ls.docs.forEach(d=>{const dd=d.data();if(dd.teamId)lt[d.id]=dd.teamId});const tm={};tms.docs.forEach(d=>tm[d.id]={...d.data(),id:d.id,sumWpm:0,sumAcc:0,cnt:0});const seen=new Map();rs.docs.filter(d=>d.data().status!=='abandoned').forEach(d=>{const r=d.data();if(!seen.has(r.learnerId)||seen.get(r.learnerId).wpm<r.wpm)seen.set(r.learnerId,r)});seen.forEach((r,lid)=>{const tid=lt[lid];if(tid&&tm[tid]){tm[tid].sumWpm+=r.wpm;tm[tid].sumAcc+=ga(r);tm[tid].cnt++}});const teams=Object.values(tm).filter(t=>t.cnt>0).sort((a,b)=>b.sumWpm-a.sumWpm);if(!teams.length){$('lbl').innerHTML='<p style="padding:14px;color:var(--sub)">No team results yet.</p>';return}$('lbl').innerHTML=teams.map((t,i)=>`<div class="lbr"><div class="lbrk ${i===0?'g':i===1?'s':i===2?'b':''}">#${i+1}</div><div style="flex:1;font-weight:600"><span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:${t.color||'#999'};margin-right:5px;vertical-align:middle"></span>${t.name}</div><div style="flex:1;font-size:.78rem;color:var(--sub)">${t.cnt} members</div><div style="font-family:monospace;font-weight:700;font-size:1rem">${t.sumWpm} WPM</div><div style="margin-left:9px;color:var(--sub);font-size:.83rem">${t.cnt?Math.round(t.sumAcc/t.cnt):0}% avg</div></div>`).join('')}catch(e){$('lbl').innerHTML='<p style="padding:14px;color:var(--bad)">Error.</p>'}}
function swLbTab(m){S.lbMode=m;$('lti').classList.toggle('active',m==='i');$('ltt').classList.toggle('active',m==='t');loadLB()}

