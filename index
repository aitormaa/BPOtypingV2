// UPDATED endTest: saves language field
function endTest(){
  clearInterval(S.tmr);$('hi').onkeydown=null;
  if(S.raceId){leaveRace();return}
  if(S.startT&&S.user&&S.test){
    const el=Math.max(1,(Date.now()-S.startT)/1e3);
    const wpm=Math.max(0,Math.round((S.cc/5)/(el/60)));
    const acc=S.typed>0?Math.round((S.cc/S.typed)*100):100;
    const level=S.test.level||'beginner';
    const{grade,score}=gradeOf(wpm,acc,level);
    db.collection('results').add({learnerId:S.user.id,learnerName:S.user.name,testId:S.test.id,testTitle:S.test.title,wpm,acc,grade,score,level,time:Math.round(el),errors:S.errs,language:S.test.language||null,status:'abandoned',createdAt:FV.serverTimestamp()}).catch(()=>{});
  }
  showView('library');renderLib();
}

