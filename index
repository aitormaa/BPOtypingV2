// UPDATED: loads personal bests in parallel with tests
async function loadLib(){
  $('tl').innerHTML='<p style="color:var(--sub);padding:8px 0">Loading...</p>';
  try{
    const bestsQ=S.user?db.collection('results').where('learnerId','==',S.user.id).where('status','==','completed').get():Promise.resolve({docs:[]});
    const[ts,ss,bs]=await Promise.all([db.collection('tests').where('active','==',true).get(),db.collection('settings').doc('app').get(),bestsQ]);
    S.featId=ss.exists?(ss.data().featuredTestId||null):null;
    S.allTests=ts.docs.map(d=>({id:d.id,...d.data()}));
    const lo={beginner:0,intermediate:1};
    S.allTests.sort((a,b)=>{if(a.id===S.featId)return-1;if(b.id===S.featId)return 1;return(lo[a.level||'beginner']||0)-(lo[b.level||'beginner']||0)});
    // build personal bests map
    S.myBests={};
    bs.docs.forEach(d=>{const r=d.data();if(!S.myBests[r.testId]||r.wpm>S.myBests[r.testId].wpm)S.myBests[r.testId]={wpm:r.wpm,grade:r.grade,score:r.score,acc:ga(r)};});
    S.langFilter='all';
    renderLib();buildLangTabs();
  }catch(e){$('tl').innerHTML='<p style="color:var(--bad)">Error loading tests.</p>'}
}

function buildLangTabs(){
  const langs=[...new Set(S.allTests.map(t=>t.language||'').filter(Boolean))].sort();
  const el=$('lang-tabs');
  if(!langs.length){el.style.display='none';return}
  el.style.display='flex';
  el.innerHTML=`<button class="lf-tab on" onclick="filterLang('all',this)">🌐 All</button>`+langs.map(l=>`<button class="lf-tab" onclick="filterLang('${l.replace(/'/g,"\\'")}',this)">${l}</button>`).join('');
}

function filterLang(lv,btn){S.langFilter=lv;document.querySelectorAll('#lang-tabs .lf-tab').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderLib();}
function filterLevel(lv,btn){S.lvlFilter=lv;document.querySelectorAll('#lvl-tabs .lf-tab').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderLib();}

function renderLib(){
  const f=S.lvlFilter,lg=S.langFilter;
  function testMatch(t){return(f==='all'||f===(t.level||'beginner'))&&(lg==='all'||(t.language||'')===(lg))}
  const feat=S.allTests.find(t=>t.id===S.featId);
  $('fw').innerHTML=(feat&&testMatch(feat))?tCard(feat,true):'';
  const rest=S.allTests.filter(t=>t.id!==S.featId&&testMatch(t));
  $('tl').innerHTML=rest.length?rest.map(t=>tCard(t,false)).join(''):'<p style="color:var(--sub);padding:8px 0">No tests for this filter.</p>';
}

// UPDATED tCard: personal best badge shown when available
function tCard(t,feat){
  const wc=t.text?(t.text.trim().split(/\s+/).length):0;
  const L=lvlInfo(t.level||'beginner');
  const langBadge=t.language?`<span style="font-size:.78rem;background:var(--bg3);padding:2px 7px;border-radius:20px">🌐 ${t.language}</span>`:'';
  const pb=S.myBests?.[t.id];
  const pbHtml=pb?`<div class="pb-bar">🏆 Your best: <strong style="font-family:monospace">${pb.wpm} WPM</strong> <span class="tag to">${pb.grade}</span> <span style="color:var(--sub)">${pb.acc}% acc</span></div>`:'';
  return`<div class="tc-card${feat?' feat':''}" onclick="startTest('${t.id}')"><div style="flex:1"><div style="font-weight:700;font-size:1rem;margin-bottom:4px">${t.title||'Untitled'}${feat?'<span class="fb">⭐ FEATURED</span>':''}</div><div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap"><span class="lvl lvl-${L.cls}">${L.emoji} ${L.label}</span>${langBadge}<span style="font-size:.78rem;color:var(--sub)">${wc} words · ${t.duration||60}s${t.category?' · '+t.category:''}</span></div>${pbHtml}</div><div style="color:var(--sub);font-size:1.2rem;flex-shrink:0">→</div></div>`;
}

function showJoinRace(){const c=prompt('Enter race code:');if(c)joinRace(c.trim().toUpperCase())}
async function startTest(id){const doc=await db.collection('tests').doc(id).get();if(!doc.exists){toast('Test not found.');return}S.test={id:doc.id,...doc.data()};S.raceId=null;$('rh').style.display='none';initEngine();showView('test')}
function initEngine(){const words=S.test.text.trim().split(/\s+/);S.words=words;S.wEls=[];S.wI=0;S.cI=0;S.errs=0;S.typed=0;S.cc=0;S.startT=null;S.tLeft=S.test.duration||60;S.rWU=0;clearInterval(S.tmr);$('tt').textContent=S.test.title||'Test';$('sw').textContent='0';$('sa').textContent='100';$('st').textContent=S.tLeft;$('se').textContent='0';$('tpb').style.width='0';const wi=$('wi');wi.style.transform='translateY(0)';wi.innerHTML='';words.forEach((w)=>{const el=document.createElement('div');el.className='word';[...w].forEach(ch=>{const s=document.createElement('span');s.className='ch';s.textContent=ch;el.appendChild(s)});wi.appendChild(el);S.wEls.push(el)});hlCur();fhi();$('hi').value='';$('hi').onkeydown=handleKey}
function fhi(){$('hi').focus({preventScroll:true})}
function getChs(i){return S.wEls[i]?Array.from(S.wEls[i].querySelectorAll('.ch')):[]}
function hlCur(){document.querySelectorAll('.ch.cur').forEach(e=>e.classList.remove('cur'));const chs=getChs(S.wI);const t=chs[S.cI]||chs[chs.length-1];if(t)t.classList.add('cur')}
function autoScroll(){const el=S.wEls[S.wI];if(!el)return;const lh=S.wEls[0]?S.wEls[0].offsetHeight:40;$('wi').style.transform=`translateY(-${Math.max(0,el.offsetTop-lh)}px)`}
function handleKey(e){
  if(e.key==='Tab'){e.preventDefault();return}
  const k=e.key;if(k.length!==1&&k!=='Backspace')return;
  if(!S.startT){S.startT=Date.now();runTimer()}
  const chs=getChs(S.wI);const word=S.words[S.wI]||'';
  if(k==='Backspace'){
    e.preventDefault();
    if(S.cI>0){S.cI--;chs[S.cI].className='ch';hlCur();}
    else if(S.wI>0){S.wEls[S.wI].classList.remove('wa');S.wI--;const pc=getChs(S.wI);S.cI=S.words[S.wI].length-1;pc[S.cI].className='ch';S.wEls[S.wI].classList.add('wa');hlCur();autoScroll();}
    return;
  }
  if(k===' '){e.preventDefault();if(S.wI>=S.words.length-1){finTest();return}S.wEls[S.wI].classList.remove('wa');S.wI++;S.cI=0;S.rWU=(S.rWU||0)+1;if(S.raceId&&S.rWU>=5){updRaceP();S.rWU=0}S.wEls[S.wI].classList.add('wa');autoScroll();hlCur();updStats();return}
  if(S.cI>=word.length)return;
  S.typed++;const ok=(k===word[S.cI]);
  chs[S.cI].className='ch '+(ok?'ok':'wbd');
  if(ok)S.cc++;else S.errs++;
  playClick(ok);S.cI++;
  if(S.cI>=word.length&&S.wI>=S.words.length-1){setTimeout(finTest,100);return}
  hlCur();updStats()
}
function runTimer(){$('st').textContent=S.tLeft;S.tmr=setInterval(()=>{S.tLeft--;$('st').textContent=S.tLeft;const el=S.startT?(Date.now()-S.startT)/6e4:0;$('sw').textContent=el>0?Math.round((S.cc/5)/el):0;if(S.tLeft<=0)finTest()},1000)}
function updStats(){const el=S.startT?(Date.now()-S.startT)/6e4:0;const w=el>0?Math.round((S.cc/5)/el):0;const a=S.typed>0?Math.round((S.cc/S.typed)*100):100;$('sw').textContent=w;$('sa').textContent=a;$('se').textContent=S.errs;$('tpb').style.width=(S.words.length>0?Math.round((S.wI/S.words.length)*100):0)+'%'}
async function finTest(){clearInterval(S.tmr);$('hi').onkeydown=null;const el=S.startT?(Date.now()-S.startT)/1e3:1;const wpm=el>0?Math.round((S.cc/5)/(el/60)):0;const acc=S.typed>0?Math.round((S.cc/S.typed)*100):100;const level=S.test.level||'beginner';const{grade,score}=gradeOf(wpm,acc,level);if(S.raceId){await finRaceP(wpm,el);return}S.lastR={wpm,acc,grade,score,level,time:Math.round(el),errs:S.errs,testId:S.test.id,testTitle:S.test.title};showResults(S.lastR);autoSaveResult(S.lastR);}
function showResults(r){$('rgc').textContent=r.grade;$('rgc').className='gc g'+r.grade;const L=lvlInfo(r.level);$('rlvlb').innerHTML=`<span class="lvl lvl-${L.cls}">${L.emoji} ${L.label}</span>`;$('rgl').textContent=GL[r.grade]||'Done!';$('rscore').textContent=`Score: ${r.score} · ${L.label} level`;$('rw').textContent=r.wpm;$('ra').textContent=r.acc+'%';$('rsc').textContent=r.score;$('rt').textContent=r.time+'s';$('re').textContent=r.errs;$('rbe').innerHTML='';$('saveStatus').textContent='💾 Saving result...';$('saveStatus').style.color='var(--sub)';showView('results')}
function pKey(){return'tt_pend_'+(S.user?.id||'x')}
function savePending(r){const k=pKey();const list=JSON.parse(localStorage.getItem(k)||'[]');if(!list.find(p=>p.testId===r.testId&&p.time===r.time)){list.push({...r,learnerId:S.user.id,learnerName:S.user.name,failedAt:new Date().toISOString()});localStorage.setItem(k,JSON.stringify(list))}}
function clearPending(r){const k=pKey();let list=JSON.parse(localStorage.getItem(k)||'[]');list=list.filter(p=>!(p.testId===r.testId&&p.time===r.time));localStorage.setItem(k,JSON.stringify(list))}
async function syncPending(){if(!S.user)return;const k=pKey();const list=JSON.parse(localStorage.getItem(k)||'[]');if(!list.length)return;let n=0;const rem=[];for(const r of list){try{await db.collection('results').add({...r,createdAt:FV.serverTimestamp()});n++;}catch(e){rem.push(r)}}localStorage.setItem(k,JSON.stringify(rem));if(n>0)toast(`✅ ${n} pending result${n>1?'s':''} synced!`)}

// UPDATED autoSaveResult: now saves language field + updates myBests
async function autoSaveResult(r){
  try{
    await db.collection('results').add({learnerId:S.user.id,learnerName:S.user.name,testId:r.testId,testTitle:r.testTitle,wpm:r.wpm,acc:r.acc,grade:r.grade,score:r.score,level:r.level,time:r.time,errors:r.errs,language:S.test?.language||null,status:'completed',createdAt:FV.serverTimestamp()});
