<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>BM Typing Test</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--accent:#f4a623;--bad:#e74c3c;--green:#27ae60;--sub:#9e9ea0;--bg:#f0f1f3;--bg2:#fff;--bg3:#e4e5e7;--text:#2c2e31;--r:8px;--sh:0 2px 12px rgba(0,0,0,.08)}
body{font-family:'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
.hi{position:fixed;top:-200px;left:-200px;width:1px;height:1px;opacity:0;pointer-events:none}
.view{display:none;min-height:100vh;padding:20px 16px;flex-direction:column;align-items:center}
.view.active{display:flex}
.card{background:var(--bg2);border-radius:var(--r);box-shadow:var(--sh);padding:24px 28px;width:100%;max-width:520px}
input[type=text],input[type=email],select,textarea{width:100%;border:2px solid var(--bg3);border-radius:6px;padding:10px 14px;font-size:.95rem;color:var(--text);background:var(--bg2);outline:none;transition:border .2s}
input[type=text]:focus,input[type=email]:focus,select:focus,textarea:focus{border-color:var(--accent)}
textarea{resize:vertical;font-family:'Courier New',monospace}
button{cursor:pointer;border:none;border-radius:6px;padding:9px 18px;font-size:.9rem;font-weight:600;transition:opacity .15s,transform .1s}
button:active{transform:scale(.97)}
button:disabled{opacity:.38;cursor:not-allowed;transform:none!important}
.ba{background:var(--accent);color:#fff}.ba:not(:disabled):hover{opacity:.88}
.bo{background:transparent;border:2px solid var(--bg3);color:var(--text)}.bo:not(:disabled):hover{border-color:var(--sub)}
.bd{background:var(--bad);color:#fff}
.bs{padding:6px 13px;font-size:.83rem}
.topbar{width:100%;max-width:900px;display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap}
.topbar h1{font-size:1.35rem;flex:1}
#tc{position:fixed;top:14px;right:14px;z-index:9999;display:flex;flex-direction:column;gap:7px;pointer-events:none}
.toast{background:#2c2e31;color:#fff;padding:11px 16px;border-radius:8px;font-size:.88rem;animation:tIn .3s ease;box-shadow:0 4px 16px rgba(0,0,0,.25);max-width:300px}
@keyframes tIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}
#v-welcome .card{margin-top:48px;text-align:center}
.field{margin-bottom:11px;text-align:left}
.field label{display:block;font-size:.77rem;font-weight:700;color:var(--sub);text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px}
.lf-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.lf-tab{background:var(--bg2);border:2px solid var(--bg3);border-radius:20px;padding:6px 14px;font-size:.84rem;font-weight:600;cursor:pointer;transition:all .15s;color:var(--sub)}
.lf-tab:hover{border-color:var(--sub);color:var(--text)}
.lf-tab.on{border-color:var(--accent);background:var(--accent);color:#fff}
.lf-tab.on.beg{border-color:#27ae60;background:#27ae60}
.lf-tab.on.int{border-color:#2980b9;background:#2980b9}
.tc-card{background:var(--bg2);border:2px solid var(--bg3);border-radius:var(--r);padding:16px 18px;margin-bottom:10px;cursor:pointer;transition:border-color .2s,box-shadow .2s;display:flex;justify-content:space-between;align-items:center;gap:10px}
.tc-card:hover{border-color:var(--accent);box-shadow:var(--sh)}
.tc-card.feat{border-color:var(--accent);background:linear-gradient(135deg,#fffbf0,#fff)}
.fb{background:var(--accent);color:#fff;font-size:.7rem;font-weight:700;padding:2px 7px;border-radius:20px;margin-left:6px;vertical-align:middle}
.lvl{display:inline-block;font-size:.7rem;font-weight:700;padding:2px 8px;border-radius:20px;vertical-align:middle}
.lvl-beginner{background:#edfaf3;color:#27ae60}
.lvl-intermediate{background:#eaf4fb;color:#2980b9}
.gscale{margin-top:18px;background:var(--bg);border-radius:8px;padding:14px 16px;text-align:left}
.gscale h4{font-size:.75rem;color:var(--sub);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px}
.gs-tabs{display:flex;gap:3px;margin-bottom:10px}
.gs-tab{flex:1;padding:5px;text-align:center;border-radius:5px;font-size:.77rem;font-weight:700;cursor:pointer;border:none;background:var(--bg3);color:var(--sub);transition:all .15s}
.gs-tab.on.b{background:#27ae60;color:#fff}.gs-tab.on.i{background:#2980b9;color:#fff}
.gs-row{display:flex;align-items:center;gap:8px;padding:4px 0;border-bottom:1px solid var(--bg3)}
.gs-row:last-child{border-bottom:none}
.gs-gr{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:900;border:2px solid;flex-shrink:0}
#v-test{padding:12px 16px}
#th{width:100%;max-width:820px;display:flex;align-items:center;gap:14px;margin-bottom:14px}
#th div{font-size:1.05rem;font-weight:700;flex:1}
#rh{width:100%;max-width:820px;background:var(--bg2);border-radius:var(--r);padding:12px 16px;margin-bottom:12px;border:2px solid var(--bg3);display:none}
#rh h4{font-size:.82rem;color:var(--sub);margin-bottom:8px}
.rpr{display:flex;align-items:center;gap:9px;margin-bottom:6px;font-size:.86rem}
.rpr-n{width:105px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:600}
.rb-w{flex:1;height:9px;background:var(--bg3);border-radius:5px;overflow:hidden}
.rb{height:100%;background:var(--accent);transition:width .4s;border-radius:5px}
.rpr-w{width:52px;text-align:right;color:var(--sub);font-size:.78rem}
#ww{width:100%;max-width:820px;height:152px;overflow:hidden;background:var(--bg2);border-radius:var(--r);padding:14px 18px;box-shadow:var(--sh);cursor:text}
#wi{will-change:transform;transition:transform .12s ease}
.word{display:inline-flex;margin:0 5px 7px 0}
.ch{font-size:1.32rem;line-height:1.7;font-family:'Courier New',monospace;position:relative;border-radius:3px}
.ch.cur{background:var(--accent);color:#fff!important;border-radius:3px;padding:0 1px}
.ch.ok{color:var(--green)}.ch.wbd{color:var(--bad)}
#ts{width:100%;max-width:820px;display:flex;gap:22px;margin-top:12px;font-size:.95rem;color:var(--sub)}
#ts span{display:flex;flex-direction:column;align-items:center}
#ts strong{font-size:1.35rem;color:var(--text);font-family:monospace}
#tp{width:100%;max-width:820px;height:4px;background:var(--bg3);border-radius:2px;margin-top:8px}
#tpb{height:4px;background:var(--accent);border-radius:2px;transition:width .3s}
.gc{width:96px;height:96px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2.7rem;font-weight:900;margin:0 auto 10px;border:4px solid}
.gA{color:#27ae60;border-color:#27ae60;background:#edfaf3}
.gB{color:#2980b9;border-color:#2980b9;background:#eaf4fb}
.gC{color:#8e44ad;border-color:#8e44ad;background:#f5eef8}
.gD{color:#e67e22;border-color:#e67e22;background:#fef9ec}
.gF{color:#e74c3c;border-color:#e74c3c;background:#fdf0ef}
.rs{display:flex;gap:18px;justify-content:center;margin:12px 0 14px;flex-wrap:wrap}
.rs div{display:flex;flex-direction:column;align-items:center}
.rs strong{font-size:1.45rem;font-family:monospace}.rs span{font-size:.72rem;color:var(--sub);text-transform:uppercase;letter-spacing:.05em}
.rs .score-stat strong{color:var(--accent)}
.save-status{text-align:center;font-size:.84rem;padding:8px 0 14px;transition:color .3s}
.ph{display:flex;align-items:center;gap:14px;margin-bottom:18px}
.pa{width:56px;height:56px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:1.5rem;font-weight:700;color:#fff}
.ps{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:18px}
.ps div{background:var(--bg);border-radius:6px;padding:10px 14px;text-align:center;min-width:75px}
.ps strong{display:block;font-size:1.35rem;font-family:monospace}.ps span{font-size:.73rem;color:var(--sub)}
.bg-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(60px,1fr));gap:9px;margin-top:8px}
.bi{display:flex;flex-direction:column;align-items:center;gap:3px;padding:7px 3px;border-radius:6px;background:var(--bg);text-align:center}
.bi .ic{font-size:1.5rem}.bi .nm{font-size:.66rem;color:var(--sub);line-height:1.2}
.bi.lk{opacity:.28;filter:grayscale(1)}
.cw{background:var(--bg);border-radius:6px;padding:11px;margin:10px 0}
.cw h4{font-size:.8rem;color:var(--sub);margin-bottom:7px}
.lb-tabs{display:flex;margin-bottom:14px;border-radius:6px;overflow:hidden;border:2px solid var(--bg3)}
.lbt{flex:1;padding:8px;text-align:center;cursor:pointer;font-size:.88rem;font-weight:600;background:var(--bg2);border:none;transition:background .15s}
.lbt.active{background:var(--accent);color:#fff}
.lbr{display:flex;align-items:center;gap:11px;padding:11px 15px;border-bottom:1px solid var(--bg3);font-size:.9rem}
.lbr:last-child{border-bottom:none}
.lbrk{width:26px;font-weight:700;color:var(--sub);font-family:monospace}
.lbrk.g{color:#f4a623}.lbrk.s{color:#95a5a6}.lbrk.b{color:#cd7f32}
.adm-tabs{display:flex;gap:3px;margin-bottom:0;flex-wrap:wrap}
.adm-t{background:var(--bg3);border:none;border-radius:6px 6px 0 0;padding:7px 14px;cursor:pointer;font-weight:600;font-size:.85rem;transition:background .15s}
.adm-t.active{background:var(--accent);color:#fff}
.adm-p{background:var(--bg2);border-radius:0 var(--r) var(--r) var(--r);padding:18px;max-width:960px;width:100%;box-shadow:var(--sh)}
.at{width:100%;border-collapse:collapse;font-size:.86rem}
.at th{background:var(--bg);padding:7px 11px;text-align:left;font-size:.77rem;color:var(--sub);text-transform:uppercase;letter-spacing:.04em}
.at td{padding:7px 11px;border-bottom:1px solid var(--bg3);vertical-align:middle}
.at tr:last-child td{border-bottom:none}
.af{display:flex;flex-direction:column;gap:9px;margin-bottom:18px;max-width:460px}
.af label{font-size:.83rem;font-weight:600;margin-bottom:1px}
.tag{display:inline-block;border-radius:20px;padding:2px 8px;font-size:.73rem;font-weight:700}
.tg{background:#edfaf3;color:var(--green)}.tgr{background:var(--bg3);color:var(--sub)}.to{background:#fff8ec;color:var(--accent)}
.tab{background:#fff3cd;color:#856404}
.df-btn{padding:5px 11px;font-size:.8rem;font-weight:600;border-radius:20px;border:2px solid var(--bg3);background:var(--bg2);cursor:pointer;color:var(--sub);transition:all .15s}
.df-btn.on{border-color:var(--accent);background:var(--accent);color:#fff}
.pb-bar{margin-top:6px;padding:5px 8px;background:var(--bg);border-radius:5px;font-size:.75rem;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
#rl-card{text-align:center}
.lc{font-size:2.8rem;font-family:monospace;font-weight:900;letter-spacing:.15em;color:var(--accent);margin:10px 0}
.lpl div{background:var(--bg);border-radius:6px;padding:9px 13px;font-weight:600;margin-bottom:6px}
#pod{display:flex;justify-content:center;align-items:flex-end;gap:10px;margin:18px 0}
.pc{display:flex;flex-direction:column;align-items:center;gap:5px}
.pb-p{border-radius:6px 6px 0 0;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:900;color:#fff;width:76px}
.p1{height:86px;background:var(--accent)}.p2{height:62px;background:#95a5a6}.p3{height:44px;background:#cd7f32}
.pn{font-size:.8rem;font-weight:700;text-align:center;max-width:76px}.pw{font-size:.73rem;color:var(--sub)}
.em-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px}
.em-box{background:#fff;border-radius:var(--r);padding:24px;width:100%;max-width:580px;max-height:90vh;overflow-y:auto;box-shadow:0 12px 40px rgba(0,0,0,.25)}
@media(max-width:600px){.card{padding:18px 14px}#ww{height:152px}.rs{gap:12px}}
</style>
</head>
<body>
<input class="hi" id="hi" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
<div id="tc"></div>
<div id="v-welcome" class="view active">
  <div class="card">
    <div style="text-align:center;margin-bottom:22px">
      <div style="font-size:2.2rem;margin-bottom:4px">⌨️</div>
      <h1 style="font-size:1.7rem;margin-bottom:5px">BM Typing Test</h1>
      <p style="color:var(--sub)">Sign in to track your progress</p>
    </div>
    <div class="field"><label>Full name <span style="color:var(--sub);font-weight:400;font-size:.72rem">(optional on return)</span></label><input type="text" id="ni" placeholder="e.g. Laura Smith" maxlength="40"></div>
    <div class="field"><label>Back Market email</label><input type="email" id="ei" placeholder="name.surname@backmarket.com" maxlength="80" onkeydown="if(event.key==='Enter')doWelcome()"></div>
    <div class="field" id="teamField" style="display:none"><label>Team</label><select id="teamSel"><option value="">— Select your team —</option></select></div>
    <button class="ba" style="width:100%;padding:12px;margin-top:4px" onclick="doWelcome()">Let's Go →</button>
    <div class="gscale">
      <h4>Grading — Score = WPM × Accuracy</h4>
      <div class="gs-tabs">
        <button class="gs-tab on b" onclick="showGsTab('beginner',this)">🌱 Beginner</button>
        <button class="gs-tab i" onclick="showGsTab('intermediate',this)">📘 Intermediate</button>
      </div>
      <div id="gs-body"></div>
    </div>
  </div>
</div>
<div id="v-library" class="view">
  <div class="topbar" style="max-width:720px">
    <h1>📚 Tests</h1>
    <button class="bo bs" onclick="showView('profile')">👤 Profile</button>
    <button class="bo bs" onclick="loadLB();showView('leaderboard')">🏆 Board</button>
    <button class="ba bs" onclick="showJoinRace()">🏎️ Race</button>
  </div>
  <div style="width:100%;max-width:720px">
    <div class="lf-tabs" id="lvl-tabs">
      <button class="lf-tab on" onclick="filterLevel('all',this)">All levels</button>
      <button class="lf-tab beg" onclick="filterLevel('beginner',this)">🌱 Beginner</button>
      <button class="lf-tab int" onclick="filterLevel('intermediate',this)">📘 Intermediate</button>
    </div>
    <div class="lf-tabs" id="lang-tabs" style="display:none;margin-top:-6px;margin-bottom:8px"></div>
    <div id="fw" style="margin-bottom:4px"></div>
    <div id="tl"></div>
  </div>
</div>
<div id="v-test" class="view" style="align-items:center;padding:14px 16px">
  <div id="th"><div id="tt">Test</div><button class="bo bs" onclick="endTest()">✕ Exit</button></div>
  <div id="rh"><h4>🏎️ LIVE RACE</h4><div id="rhp"></div></div>
  <div id="ww" onclick="fhi()"><div id="wi"></div></div>
  <div id="tp"><div id="tpb" style="width:0"></div></div>
  <div id="ts">
    <span><strong id="sw">0</strong>wpm</span>
    <span><strong id="sa">100</strong>%</span>
    <span><strong id="st">0</strong>sec</span>
    <span><strong id="se">0</strong>err</span>
  </div>
</div>
<div id="v-results" class="view">
  <div class="card" style="margin-top:28px;text-align:center;max-width:420px">
    <div id="rgc" class="gc gA">A</div>
    <div id="rlvlb" style="margin-bottom:6px"></div>
    <h2 id="rgl" style="margin-bottom:5px">Excellent!</h2>
    <div id="rscore" style="font-size:.84rem;color:var(--sub);margin-bottom:8px"></div>
    <div class="rs">
      <div><strong id="rw">0</strong><span>WPM</span></div>
      <div><strong id="ra">0</strong><span>Accuracy</span></div>
      <div class="score-stat"><strong id="rsc">0</strong><span>Score</span></div>
      <div><strong id="rt">0</strong><span>Seconds</span></div>
      <div><strong id="re">0</strong><span>Errors</span></div>
    </div>
    <div id="rbe" style="margin-bottom:4px"></div>
    <div class="save-status" id="saveStatus">💾 Saving...</div>
    <div style="display:flex;gap:9px;justify-content:center;flex-wrap:wrap">
      <button class="ba" onclick="retryTest()">↺ Retry</button>
      <button class="bo" onclick="showView('library');renderLib()">← Library</button>
    </div>
  </div>
</div>
<div id="v-profile" class="view">
  <div class="topbar" style="max-width:580px"><h1>👤 Profile</h1><button class="bo bs" onclick="showView('library')">← Back</button></div>
  <div class="card" style="max-width:580px">
    <div class="ph"><div class="pa" id="pav">?</div><div><h2 id="pn">-</h2><div id="pt" style="font-size:.83rem;color:var(--sub)"></div></div></div>
    <div class="ps">
      <div><strong id="pst">0</strong><span>Tests</span></div>
      <div><strong id="psb">0</strong><span>Best WPM</span></div>
      <div><strong id="psa">0</strong><span>Avg WPM</span></div>
      <div><strong id="pss">0</strong><span>🔥 Streak</span></div>
    </div>
    <div class="cw"><h4>WPM Progress (last 15)</h4><div id="wc"></div></div>
    <div><h3 style="font-size:.92rem;margin-bottom:10px">🏅 Badges</h3><div class="bg-grid" id="bgrid"></div></div>
  </div>
</div>
<div id="v-leaderboard" class="view">
  <div class="topbar" style="max-width:680px">
    <h1>🏆 Leaderboard</h1>
    <select id="lbf" onchange="loadLB()" style="width:auto;max-width:210px"></select>
    <button class="bo bs" onclick="showView('library')">← Back</button>
  </div>
  <div style="width:100%;max-width:680px">
    <div class="lb-tabs"><button class="lbt active" id="lti" onclick="swLbTab('i')">Individual</button><button class="lbt" id="ltt" onclick="swLbTab('t')">Teams</button></div>
    <div class="card" style="padding:0;overflow:hidden"><div id="lbl"></div></div>
  </div>
</div>
<div id="v-race" class="view">
  <div class="topbar" style="max-width:720px"><h1 id="rvt">🏎️ Race</h1><button class="bo bs" onclick="leaveRace()">✕ Leave</button></div>
  <div id="rl" style="width:100%;max-width:500px">
    <div class="card" id="rl-card">
      <h2 style="text-align:center;margin-bottom:4px">Waiting for race to start...</h2>
      <div class="lc" id="lcd">------</div>
      <p style="color:var(--sub);text-align:center;margin-bottom:14px">Share this code</p>
      <div id="lplayers" style="max-width:300px;margin:0 auto 18px"></div>
      <p style="color:var(--sub);font-size:.8rem;text-align:center">Admin will start shortly...</p>
    </div>
  </div>
  <div id="rpod" style="display:none;width:100%;max-width:500px">
    <div class="card" style="text-align:center">
      <h2 style="margin-bottom:14px">🏁 Race Finished!</h2>
      <div id="pod"></div><div id="ryr" style="margin:14px 0;font-size:1.05rem"></div>
      <button class="ba" onclick="showView('library');renderLib()">← Library</button>
    </div>
  </div>
</div>
<div id="v-admin" class="view" style="align-items:flex-start;padding:14px">
  <div style="width:100%;max-width:960px">
    <div style="display:flex;align-items:center;gap:11px;margin-bottom:14px">
      <h1 style="font-size:1.35rem">⚙️ Admin Panel</h1>
      <button class="bo bs" onclick="showView('library');renderLib()">← Library</button>
    </div>
    <div class="adm-tabs">
      <button class="adm-t active" onclick="aTab('tests')">Tests</button>
      <button class="adm-t" onclick="aTab('results')">Results</button>
      <button class="adm-t" onclick="aTab('learners')">Learners</button>
      <button class="adm-t" onclick="aTab('leaderboard')">Leaderboard</button>
      <button class="adm-t" onclick="aTab('races')">Races</button>
      <button class="adm-t" onclick="aTab('teams')">Teams</button>
    </div>
    <div class="adm-p" id="apc"></div>
  </div>
</div>
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-firestore-compat.js"></script>
<script>
firebase.initializeApp({apiKey:"AIzaSyDzIJ5yjEK1udHhEBlobzfd5-nWlZI7jvo",authDomain:"bm-typing-test.firebaseapp.com",projectId:"bm-typing-test",storageBucket:"bm-typing-test.firebasestorage.app",messagingSenderId:"480868721716",appId:"1:480868721716:web:24c7fed298b4fee4f1d661"});
const db=firebase.firestore();
const $=id=>document.getElementById(id);
const FV=firebase.firestore.FieldValue;

// ── STATE ──
const S={user:null,test:null,lastR:null,words:[],wEls:[],wI:0,cI:0,typed:0,errs:0,cc:0,startT:null,tmr:null,tLeft:0,raceId:null,rUnsub:null,rpUnsub:null,rWU:0,lbMode:'i',featId:null,rStarted:false,allTests:[],lvlFilter:'all',langFilter:'all',myBests:{}};
const LEVELS={beginner:{label:'Beginner',emoji:'🌱',cls:'beginner',thresholds:{A:50,B:42,C:35,D:28},desc:'Full sentences. Build consistent speed and accuracy.'},intermediate:{label:'Intermediate',emoji:'📘',cls:'intermediate',thresholds:{A:58,B:49,C:42,D:36},desc:'Complex text and industry vocabulary. Higher standard.'}};
const GL={A:"Excellent! 🎉",B:"Good Job! 👍",C:"Keep Going! 💪",D:"Practice More!",F:"Needs Improvement"};
const DUR_OPTS=[[30,'30 seconds'],[45,'45 seconds'],[60,'60 seconds'],[90,'90 seconds'],[120,'2 minutes'],[180,'3 minutes']];
function durSelect(id,val){return`<select id="${id}">${DUR_OPTS.map(([v,l])=>`<option value="${v}" ${v===(val||60)?'selected':''}>${l}</option>`).join('')}</select>`}
function gradeOf(wpm,acc,level){const score=Math.round(wpm*(acc/100)*10)/10;const t=(LEVELS[level]||LEVELS.beginner).thresholds;return{grade:score>=t.A?'A':score>=t.B?'B':score>=t.C?'C':score>=t.D?'D':'F',score};}
function showGsTab(lv,btn){document.querySelectorAll('.gs-tab').forEach(b=>{b.classList.remove('on','b','i')});btn.classList.add('on',lv==='beginner'?'b':'i');const L=LEVELS[lv];const t=L.thresholds;$('gs-body').innerHTML=`<p style="font-size:.75rem;color:var(--sub);margin-bottom:8px">${L.desc}</p>`+[['A',`≥${t.A}`],['B',`≥${t.B}`],['C',`≥${t.C}`],['D',`≥${t.D}`],['F',`< ${t.D}`]].map(([g,m])=>`<div class="gs-row"><div class="gs-gr g${g}">${g}</div><div style="flex:1"><strong>${m}</strong></div></div>`).join('');}
const BADGES=[["first","First Steps","🎯","Complete first test"],["w50","Speed Demon","💨","Score 50+"],["w70","Rocket","🚀","Score 70+"],["w80","Lightning","⚡","Score 80+"],["acc100","Perfect","💎","100% accuracy"],["att10","Dedicated","🔟","10 attempts"],["att25","Grinder","🏋️","25 attempts"],["sk3","On Fire","🔥","3-day streak"],["sk7","Week Warrior","🌟","7-day streak"],["agrade","Elite","🏆","Achieve grade A"],["top1","Champion","👑","#1 on leaderboard"],["racer","Speed Racer","🏎️","Finish a race"]];
function gmK(){return'tt_gm_'+(S.user?S.user.id:'x')}
function gmG(){try{return JSON.parse(localStorage.getItem(gmK()))||{badges:[],streak:0,lastDay:'',wpmHistory:[]}}catch(e){return{badges:[],streak:0,lastDay:'',wpmHistory:[]}}}
function gmS(d){localStorage.setItem(gmK(),JSON.stringify(d))}
function gmStreak(d){const today=new Date().toISOString().slice(0,10);if(d.lastDay===today)return;const yd=new Date(Date.now()-864e5).toISOString().slice(0,10);d.streak=d.lastDay===yd?(d.streak||0)+1:1;d.lastDay=today}
function gmCheck(score,acc,gm,att){const nb=[];function u(id){if(!gm.badges.includes(id)){gm.badges.push(id);nb.push(id)}}u('first');if(score>=50)u('w50');if(score>=70)u('w70');if(score>=80)u('w80');if(acc>=100)u('acc100');if(att>=10)u('att10');if(att>=25)u('att25');if(gm.streak>=3)u('sk3');if(gm.streak>=7)u('sk7');return nb}
function ga(r){return r.acc!=null?r.acc:r.accuracy!=null?r.accuracy:0}
let aCtx=null;
function playClick(ok){try{if(!aCtx)aCtx=new(window.AudioContext||window.webkitAudioContext)();if(aCtx.state==='suspended')aCtx.resume();const now=aCtx.currentTime;if(!ok){const osc=aCtx.createOscillator(),g=aCtx.createGain();osc.type='sine';osc.frequency.value=180;g.gain.setValueAtTime(0.18,now);g.gain.exponentialRampToValueAtTime(0.001,now+0.09);osc.connect(g);g.connect(aCtx.destination);osc.start(now);osc.stop(now+0.09);}else{const len=Math.floor(aCtx.sampleRate*0.018);const buf=aCtx.createBuffer(1,len,aCtx.sampleRate);const d=buf.getChannelData(0);for(let i=0;i<len;i++)d[i]=(Math.random()*2-1)*Math.exp(-i*12/len);const src=aCtx.createBufferSource();src.buffer=buf;const hp=aCtx.createBiquadFilter();hp.type='highpass';hp.frequency.value=1800;const g=aCtx.createGain();g.gain.value=0.55;src.connect(hp);hp.connect(g);g.connect(aCtx.destination);src.start(now);}}catch(e){}}
function showView(n){document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));const el=$('v-'+n);if(el)el.classList.add('active');if(n==='profile')renderProfile()}
function toast(msg,dur=3500){const d=document.createElement('div');d.className='toast';d.textContent=msg;$('tc').appendChild(d);setTimeout(()=>d.remove(),dur)}
function randCode(){const c='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';return Array.from({length:6},()=>c[Math.floor(Math.random()*c.length)]).join('')}
