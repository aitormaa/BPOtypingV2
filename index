async function aAddTest(){const t=($('at-t').value||'').trim(),x=($('at-x').value||'').trim(),d=parseInt($('at-d').value)||60,c=($('at-c').value||'').trim(),l=$('at-l').value||'beginner',lng=($('at-lang').value||'').trim();if(!t||!x){toast('Title and text required.');return}await db.collection('tests').add({title:t,text:x,duration:d,category:c||null,level:l,language:lng||null,active:true,createdAt:FV.serverTimestamp()});toast('Test added!');aTests()}
