async function procGM(r){const gm=gmG();gmStreak(gm);gm.wpmHistory=gm.wpmHistory||[];gm.wpmHistory.push(r.wpm);if(gm.wpmHistory.length>15)gm.wpmHistory=gm.wpmHistory.slice(-15);let att=0;try{const sn=await db.collection('results').where('learnerId','==',S.user.id).where('status','==','completed').get();att=sn.size}catch(e){}const nb=gmCheck(r.score,r.acc,gm,att);if(r.grade==='A'&&!gm.badges.includes('agrade')){gm.badges.push('agrade');nb.push('agrade')}gmS(gm);nb.forEach(id=>{const b=BADGES.find(x=>x[0]===id);if(b)setTimeout(()=>toast(`🏅 Badge: ${b[2]} ${b[1]}!`),400)});if(nb.length){$('rbe').innerHTML='<div style="color:var(--accent);font-weight:700;margin-top:4px">🏅 '+nb.map(id=>{const b=BADGES.find(x=>x[0]===id);return b?b[2]+' '+b[1]:id}).join(' · ')+'</div>'}}
async function chkTop1(r){try{const sn=await db.collection('results').where('testId','==',r.testId).where('status','==','completed').orderBy('wpm','desc').limit(1).get();if(!sn.empty&&sn.docs[0].data().learnerId===S.user.id){setTimeout(()=>toast(`👑 You're #1 on ${r.testTitle||'this test'}!`),800);const gm=gmG();if(!gm.badges.includes('top1')){gm.badges.push('top1');gmS(gm);toast('🏅 Badge: 👑 Champion!')}}}catch(e){}}
async function renderProfile(){if(!S.user)return;$('pn').textContent=S.user.name;$('pav').textContent=S.user.name[0].toUpperCase();$('pt').innerHTML='';if(S.user.teamId){try{const td=await db.collection('teams').doc(S.user.teamId).get();if(td.exists){const t=td.data();$('pt').innerHTML=`<span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:${t.color||'#999'};margin-right:4px"></span>${t.name}`+(S.user.email?` · <span style="color:var(--sub)">${S.user.email}</span>`:'')}}}catch(e){}else if(S.user.email){$('pt').innerHTML=`<span style="color:var(--sub)">${S.user.email}</span>`}const gm=gmG();$('pss').textContent=gm.streak||0;try{const sn=await db.collection('results').where('learnerId','==',S.user.id).where('status','==','completed').get();const res=sn.docs.map(d=>d.data());$('pst').textContent=res.length;const wpms=res.map(r=>r.wpm).filter(w=>w>0);$('psb').textContent=wpms.length?Math.max(...wpms):0;$('psa').textContent=wpms.length?Math.round(wpms.reduce((a,b)=>a+b,0)/wpms.length):0}catch(e){}$('wc').innerHTML=renderChart(gm.wpmHistory||[]);$('bgrid').innerHTML=BADGES.map(([id,nm,ic,desc])=>`<div class="bi ${gm.badges.includes(id)?'':'lk'}" title="${desc}"><span class="ic">${ic}</span><span class="nm">${nm}</span></div>`).join('')}
function renderChart(hist){if(hist.length<2)return'<p style="color:var(--sub);font-size:.83rem;text-align:center">Complete more tests to see your chart</p>';const W=290,H=110,p=12,vals=hist.slice(-15),max=Math.max(...vals,1),min=Math.min(...vals,0),rng=max-min||1;const pts=vals.map((v,i)=>{const x=p+(i/(vals.length-1))*(W-2*p),y=H-p-((v-min)/rng)*(H-2*p);return`${x.toFixed(1)},${y.toFixed(1)}`}).join(' ');const dots=vals.map((v,i)=>{const x=p+(i/(vals.length-1))*(W-2*p),y=H-p-((v-min)/rng)*(H-2*p);return`<circle cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" r="3" fill="var(--accent)"><title>${v} WPM</title></circle>`}).join('');return`<svg viewBox="0 0 ${W} ${H}" style="width:100%;height:${H}px"><polyline points="${pts}" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>${dots}<text x="${p}" y="${H-2}" font-size="9" fill="var(--sub)">${vals[0]}</text><text x="${W-p}" y="${H-2}" font-size="9" fill="var(--sub)" text-anchor="end">${vals[vals.length-1]}</text><text x="${W/2}" y="10" font-size="9" fill="var(--sub)" text-anchor="middle">Best: ${max}</text></svg>`}

