// ── ADMIN RESULTS (with test filter + date range + language in CSV) ──
let _resultRows=[];let _resultTeamFilter='';let _resultTestFilter='';let _resultDateFilter='all';
async function aResults(){
  const el=$('apc');el.innerHTML='<p style="color:var(--sub)">Loading...</p>';
  const[rs,ls,ts]=await Promise.all([db.collection('results').orderBy('createdAt','desc').get(),db.collection('learners').get(),db.collection('teams').get()]);
  const teams={};ts.docs.forEach(d=>teams[d.id]={id:d.id,...d.data()});
  const learnerTeam={};ls.docs.forEach(d=>{const dd=d.data();if(dd.teamId)learnerTeam[d.id]=dd.teamId});
  _resultRows=rs.docs.map(d=>({id:d.id,...d.data()})).map(r=>{const tid=learnerTeam[r.learnerId]||'';return{...r,_teamId:tid,_teamName:teams[tid]?.name||''};});
  _resultTeamFilter='';_resultTestFilter='';_resultDateFilter='all';
  // build unique test list from results
  const testMap={};_resultRows.forEach(r=>{if(r.testId&&r.testTitle)testMap[r.testId]=r.testTitle});
  const teamOpts='<option value="">All teams</option>'+Object.values(teams).map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  const testOpts='<option value="">All tests</option>'+Object.entries(testMap).map(([id,title])=>`<option value="${id}">${title}</option>`).join('');
  const aband=_resultRows.filter(r=>r.status==='abandoned').length;
  el.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px"><h3>Results (${_resultRows.length}${aband?' · <span class="tag tab">⚠️ '+aband+' abandoned</span>':''})</h3><button class="bs ba" onclick="exportResultsCSV()">⬇ CSV</button></div><div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;align-items:center"><select id="res-tf" onchange="applyResultFilters()" style="width:auto">${teamOpts}</select><select id="res-testf" onchange="applyResultFilters()" style="width:auto;max-width:200px">${testOpts}</select><div style="display:flex;gap:4px">${['all','30d','7d'].map(v=>`<button class="df-btn${v==='all'?' on':''}" id="rdf-${v}" onclick="setResultDateFilter('${v}')">${v==='all'?'All time':v==='30d'?'30 days':'7 days'}</button>`).join('')}</div></div><div id="res-count" style="font-size:.83rem;color:var(--sub);margin-bottom:8px"></div><div id="res-tbody"></div>`;
  renderResultsTable();
}
function setResultDateFilter(v){
  _resultDateFilter=v;
  ['all','30d','7d'].forEach(k=>{const b=$('rdf-'+k);if(b)b.classList.toggle('on',k===v)});
  applyResultFilters();
}
function applyResultFilters(){
  _resultTeamFilter=$('res-tf')?.value||'';
  _resultTestFilter=$('res-testf')?.value||'';
  renderResultsTable();
}
function resultDateOk(r){
  if(_resultDateFilter==='all')return true;
  const d=r.createdAt?.toDate?.();if(!d)return true;
  return Date.now()-d.getTime()<(_resultDateFilter==='7d'?7:30)*864e5;
}
function renderResultsTable(){
  let rows=_resultRows;
  if(_resultTeamFilter)rows=rows.filter(r=>r._teamId===_resultTeamFilter);
  if(_resultTestFilter)rows=rows.filter(r=>r.testId===_resultTestFilter);
  rows=rows.filter(resultDateOk);
  const cnt=$('res-count');if(cnt)cnt.textContent=`Showing ${rows.length} result${rows.length!==1?'s':''}`;
  if(!rows.length){$('res-tbody').innerHTML='<p style="color:var(--sub);padding:14px 0">No results match this filter.</p>';return}
  $('res-tbody').innerHTML=`<table class="at"><thead><tr><th>Learner</th><th>Team</th><th>Test</th><th>Lang</th><th>Level</th><th>WPM</th><th>Acc</th><th>Score</th><th>Grade</th><th>Status</th><th>Date</th><th></th></tr></thead><tbody>${rows.map(r=>{const L=lvlInfo(r.level||'beginner');const isAb=r.status==='abandoned';return`<tr style="${isAb?'opacity:.75':''}"><td>${r.learnerName||'?'}</td><td style="font-size:.82rem">${r._teamName?`<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--accent);margin-right:4px;vertical-align:middle"></span>${r._teamName}`:'<span style="color:var(--sub)">—</span>'}</td><td style="color:var(--sub);font-size:.8rem">${r.testTitle||''}</td><td style="font-size:.8rem">${r.language||'<span style="color:var(--sub)">—</span>'}</td><td><span class="lvl lvl-${L.cls}">${L.emoji}</span></td><td><strong>${r.wpm}</strong></td><td>${ga(r)}%</td><td style="font-family:monospace">${r.score||'—'}</td><td><span class="tag to">${r.grade||'?'}</span></td><td>${isAb?'<span class="tag tab">⚠️ Quit</span>':'<span class="tag tg">✓ Done</span>'}</td><td style="color:var(--sub);font-size:.78rem;white-space:nowrap">${r.createdAt?.toDate?.()?.toLocaleDateString?.('en-GB')||'—'}</td><td><button class="bs bd" onclick="aDel('results','${r.id}',aResults)">Del</button></td></tr>`}).join('')}</tbody></table>`;
}
// UPDATED: includes Language column
function exportResultsCSV(){
  let rows=_resultRows;
  if(_resultTeamFilter)rows=rows.filter(r=>r._teamId===_resultTeamFilter);
  if(_resultTestFilter)rows=rows.filter(r=>r.testId===_resultTestFilter);
  rows=rows.filter(resultDateOk);
  if(!rows.length){toast('No results to export.');return}
  dlCSV(['Learner','Team','Test','Language','Level','WPM','Accuracy(%)','Score','Grade','Status','Time(s)','Errors','Date'],rows.map(r=>[r.learnerName,r._teamName||'',r.testTitle,r.language||'',r.level||'beginner',r.wpm,ga(r),r.score||'',r.grade,r.status||'completed',r.time,r.errors,r.createdAt?.toDate?.()?.toISOString?.()??'']),'results');
}

// ── ADMIN LEARNERS (team filter + clickable detail) ──
let _learnerRows=[];let _learnerTeamFilter='';let _learnerTeamsMap={};
async function aLearners(){
  const el=$('apc');el.innerHTML='<p style="color:var(--sub)">Loading...</p>';
  const[ls,ts]=await Promise.all([db.collection('learners').get(),db.collection('teams').get()]);
  _learnerTeamsMap={};ts.docs.forEach(d=>_learnerTeamsMap[d.id]={id:d.id,...d.data()});
  _learnerRows=ls.docs.map(d=>({id:d.id,...d.data()})).map(l=>({...l,_teamName:l.teamId&&_learnerTeamsMap[l.teamId]?_learnerTeamsMap[l.teamId].name:'',_teamColor:l.teamId&&_learnerTeamsMap[l.teamId]?_learnerTeamsMap[l.teamId].color||'#999':'',_teamId:l.teamId||''}));
  _learnerTeamFilter='';
  const teamFilterOpts='<option value="">All teams</option>'+Object.values(_learnerTeamsMap).map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  el.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px"><h3>Learners (${_learnerRows.length})</h3><select id="lrn-tf" onchange="filterLearners(this.value)" style="width:auto">${teamFilterOpts}</select></div><div id="lrn-tbody"></div>`;
  renderLearnersTable('');
}
function filterLearners(teamId){_learnerTeamFilter=teamId;renderLearnersTable(teamId);}
function renderLearnersTable(teamId){
  const rows=teamId?_learnerRows.filter(l=>l._teamId===teamId):_learnerRows;
  if(!rows.length){$('lrn-tbody').innerHTML='<p style="color:var(--sub);padding:14px 0">No learners for this team.</p>';return}
  const topts=Object.values(_learnerTeamsMap).map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  $('lrn-tbody').innerHTML=`<table class="at"><thead><tr><th>Name</th><th>Email</th><th>Team</th><th>Assign Team</th><th></th></tr></thead><tbody>${rows.map(l=>`<tr><td><strong style="cursor:pointer;color:var(--accent);text-decoration:underline;text-decoration-style:dotted" onclick="aLearnerDetail('${l.id}','${(l.name||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'")}'')">${l.name||'?'}</strong></td><td style="color:var(--sub);font-size:.8rem">${l.email||'—'}</td><td>${l._teamName?`<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${l._teamColor};margin-right:4px"></span>${l._teamName}`:'—'}</td><td><select onchange="aAssignTeam('${l.id}',this.value)" style="width:auto"><option value="">No team</option>${topts}</select></td><td><button class="bs bd" onclick="aDelLearner('${l.id}','${(l.name||'').replace(/'/g,"\\'")}')">🗑</button></td></tr>`).join('')}</tbody></table>`;
}

// NEW: learner detail modal
async function aLearnerDetail(id,name){
  const m=document.createElement('div');m.className='em-overlay';m.id='em-ld';
  m.innerHTML=`<div class="em-box"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px"><h3>📋 ${name}</h3><button class="bo bs" onclick="document.getElementById('em-ld').remove()">✕ Close</button></div><p style="color:var(--sub);font-size:.85rem">Loading...</p></div>`;
  document.body.appendChild(m);m.addEventListener('click',e=>{if(e.target===m)m.remove()});
  try{
    const sn=await db.collection('results').where('learnerId','==',id).orderBy('createdAt','desc').get();
    const results=sn.docs.map(d=>({id:d.id,...d.data()}));
    const box=m.querySelector('.em-box');
    if(!results.length){box.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px"><h3>📋 ${name}</h3><button class="bo bs" onclick="document.getElementById('em-ld').remove()">✕ Close</button></div><p style="color:var(--sub)">No results yet.</p>`;return}
    const completed=results.filter(r=>r.status!=='abandoned');
    const wpms=completed.map(r=>r.wpm).filter(w=>w>0);
    const accs=completed.map(r=>ga(r));
    const avgWpm=wpms.length?Math.round(wpms.reduce((a,b)=>a+b,0)/wpms.length):0;
    const bestWpm=wpms.length?Math.max(...wpms):0;
    const avgAcc=accs.length?Math.round(accs.reduce((a,b)=>a+b,0)/accs.length):0;
    const bestAcc=accs.length?Math.max(...accs):0;
    window._ldResults={id,name,results};
    box.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px"><h3>📋 ${name}</h3><div style="display:flex;gap:8px"><button class="ba bs" onclick="dlLearnerCSV('${id}','${name.replace(/'/g,"\\'")}')">⬇ CSV</button><button class="bo bs" onclick="document.getElementById('em-ld').remove()">✕ Close</button></div></div><div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px">${[['Tests',completed.length],['Best WPM',bestWpm],['Avg WPM',avgWpm],['Avg Acc',avgAcc+'%'],['Best Acc',bestAcc+'%']].map(([l,v])=>`<div style="background:var(--bg);border-radius:6px;padding:8px 14px;text-align:center"><strong style="display:block;font-size:1.15rem;font-family:monospace">${v}</strong><span style="font-size:.72rem;color:var(--sub)">${l}</span></div>`).join('')}</div><table class="at"><thead><tr><th>Test</th><th>Lang</th><th>WPM</th><th>Acc</th><th>Score</th><th>Grade</th><th>Status</th><th>Date</th></tr></thead><tbody>${results.map(r=>{const isAb=r.status==='abandoned';return`<tr style="${isAb?'opacity:.65':''}"><td style="font-size:.82rem">${r.testTitle||'?'}</td><td style="font-size:.8rem;color:var(--sub)">${r.language||'—'}</td><td><strong>${r.wpm}</strong></td><td>${ga(r)}%</td><td style="font-family:monospace">${r.score||'—'}</td><td><span class="tag to">${r.grade||'?'}</span></td><td>${isAb?'<span class="tag tab">⚠️ Quit</span>':'<span class="tag tg">✓ Done</span>'}</td><td style="color:var(--sub);font-size:.78rem;white-space:nowrap">${r.createdAt?.toDate?.()?.toLocaleDateString?.('en-GB')||'—'}</td></tr>`}).join('')}</tbody></table>`;
  }catch(e){const box=m.querySelector('.em-box');box.innerHTML+=`<p style="color:var(--bad)">Error: ${e.message}</p>`}
}
function dlLearnerCSV(id,name){
  if(!window._ldResults||window._ldResults.id!==id){toast('Open learner detail first.');return}
  const{results}=window._ldResults;
  dlCSV(['Test','Language','WPM','Accuracy(%)','Score','Grade','Status','Time(s)','Errors','Date'],results.map(r=>[r.testTitle||'',r.language||'',r.wpm,ga(r),r.score||'',r.grade,r.status||'completed',r.time,r.errors,r.createdAt?.toDate?.()?.toISOString?.()??'']),'learner_'+name.replace(/\s+/g,'_'));
}
async function aAssignTeam(lid,tid){await db.collection('learners').doc(lid).update({teamId:tid||FV.delete()});if(S.user&&S.user.id===lid)S.user.teamId=tid||null;toast('Team updated!')}
async function aDelLearner(id,name){if(!confirm(`Delete "${name}"? Their results are kept.`))return;await db.collection('learners').doc(id).delete();toast('Deleted.');aLearners()}

// ── ADMIN LEADERBOARD (sort toggle WPM/Score + accuracy + team summary) ──
let _lbRows=[];let _lbTeamFilter='';let _lbSort='wpm';
async function aLB(){
  const el=$('apc');el.innerHTML='<p style="color:var(--sub)">Loading...</p>';
  const[rs,ls,ts]=await Promise.all([db.collection('results').orderBy('wpm','desc').get(),db.collection('learners').get(),db.collection('teams').get()]);
  const teams={};ts.docs.forEach(d=>teams[d.id]={id:d.id,...d.data()});
  const learnerTeam={};ls.docs.forEach(d=>{const dd=d.data();if(dd.teamId)learnerTeam[d.id]=dd.teamId});
  _lbRows=rs.docs.filter(d=>d.data().status!=='abandoned').map(d=>({id:d.id,...d.data()})).map(r=>{const tid=learnerTeam[r.learnerId]||'';return{...r,_teamId:tid,_teamName:teams[tid]?.name||''};});
  _lbTeamFilter='';_lbSort='wpm';
  const teamOpts='<option value="">All teams</option>'+Object.values(teams).map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  el.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px"><h3>Top Results</h3><button class="bs ba" onclick="exportLBCSV()">⬇ CSV</button></div><div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;align-items:center"><select id="lb-tf" onchange="filterLB(this.value)" style="width:auto">${teamOpts}</select><div style="display:flex;gap:4px"><button class="df-btn on" id="lbs-wpm" onclick="setLBSort('wpm')">Sort: WPM</button><button class="df-btn" id="lbs-score" onclick="setLBSort('score')">Sort: Score</button></div></div><div id="lb-tbody"></div><div id="lb-teams" style="margin-top:18px"></div>`;
  renderLBTable('');
  renderLBTeamSummary(teams,learnerTeam);
}
function setLBSort(s){_lbSort=s;$('lbs-wpm').classList.toggle('on',s==='wpm');$('lbs-score').classList.toggle('on',s==='score');renderLBTable(_lbTeamFilter);}
function filterLB(teamId){_lbTeamFilter=teamId;renderLBTable(teamId);}

// UPDATED: sort toggle + accuracy column
function renderLBTable(teamId){
  let rows=teamId?_lbRows.filter(r=>r._teamId===teamId):_lbRows;
  rows=[...rows].sort((a,b)=>_lbSort==='score'?(b.score||0)-(a.score||0):b.wpm-a.wpm);
  if(!rows.length){$('lb-tbody').innerHTML='<p style="color:var(--sub);padding:14px 0">No results for this team.</p>';return}
  $('lb-tbody').innerHTML=`<table class="at"><thead><tr><th>#</th><th>Learner</th><th>Team</th><th>Test</th><th>Level</th><th>WPM</th><th>Acc</th><th>Score</th><th>Grade</th><th></th></tr></thead><tbody>${rows.map((r,i)=>{const L=lvlInfo(r.level||'beginner');return`<tr><td>${i+1}</td><td>${r.learnerName||'?'}</td><td style="font-size:.82rem">${r._teamName?`<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--accent);margin-right:4px;vertical-align:middle"></span>${r._teamName}`:'<span style="color:var(--sub)">—</span>'}</td><td style="font-size:.82rem">${r.testTitle||''}</td><td><span class="lvl lvl-${L.cls}">${L.emoji} ${L.label}</span></td><td><strong>${r.wpm}</strong></td><td>${ga(r)}%</td><td style="font-family:monospace">${r.score||'—'}</td><td><span class="tag to">${r.grade||'?'}</span></td><td><button class="bs bd" onclick="aDel('results','${r.id}',aLB)">Del</button></td></tr>`}).join('')}</tbody></table>`;
}

// NEW: team summary card below main leaderboard table
function renderLBTeamSummary(teams,learnerTeam){
  const el=$('lb-teams');if(!el)return;
  const tm={};Object.values(teams).forEach(t=>tm[t.id]={...t,sumWpm:0,sumAcc:0,cnt:0,grades:{A:0,B:0,C:0,D:0,F:0}});
  _lbRows.forEach(r=>{const tid=r._teamId;if(tid&&tm[tid]){tm[tid].sumWpm+=r.wpm;tm[tid].sumAcc+=ga(r);tm[tid].cnt++;if(r.grade&&tm[tid].grades[r.grade]!=null)tm[tid].grades[r.grade]++}});
  const sorted=Object.values(tm).filter(t=>t.cnt>0).sort((a,b)=>b.sumWpm-a.sumWpm);
  if(!sorted.length){el.innerHTML='';return}
  el.innerHTML=`<h4 style="font-size:.83rem;color:var(--sub);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px">Team Summary</h4><table class="at"><thead><tr><th>#</th><th>Team</th><th>Members</th><th>Avg WPM</th><th>Avg Acc</th><th>A grades</th></tr></thead><tbody>${sorted.map((t,i)=>`<tr><td>${i+1}</td><td><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${t.color||'#999'};margin-right:5px;vertical-align:middle"></span><strong>${t.name}</strong></td><td>${t.cnt}</td><td style="font-family:monospace"><strong>${Math.round(t.sumWpm/t.cnt)}</strong></td><td>${Math.round(t.sumAcc/t.cnt)}%</td><td>${t.grades.A||0} <span style="color:var(--sub);font-size:.78rem">(${t.cnt?Math.round((t.grades.A/t.cnt)*100):0}%)</span></td></tr>`).join('')}</tbody></table>`;
}

// UPDATED exportLBCSV: language + accuracy
function exportLBCSV(){
  let rows=_lbTeamFilter?_lbRows.filter(r=>r._teamId===_lbTeamFilter):_lbRows;
  rows=[...rows].sort((a,b)=>_lbSort==='score'?(b.score||0)-(a.score||0):b.wpm-a.wpm);
  if(!rows.length){toast('No results to export.');return}
  const label=_lbTeamFilter?rows[0]._teamName||'team':'all-teams';
  dlCSV(['Rank','Learner','Team','Test','Language','Level','WPM','Accuracy(%)','Score','Grade'],rows.map((r,i)=>[i+1,r.learnerName,r._teamName||'',r.testTitle,r.language||'',r.level||'beginner',r.wpm,ga(r),r.score||'',r.grade]),'leaderboard_'+label);
}

// ── ADMIN RACES & TEAMS ──
async function aRaces(){const el=$('apc');el.innerHTML='<p style="color:var(--sub)">Loading...</p>';const[rs,ts]=await Promise.all([db.collection('races').orderBy('createdAt','desc').get(),db.collection('tests').where('active','==',true).get()]);const tests=ts.docs.map(d=>({id:d.id,...d.data()}));const races=rs.docs.map(d=>({id:d.id,...d.data()}));el.innerHTML=`<h3 style="margin-bottom:14px">Races</h3><div class="af"><div><label>Select Test</label><select id="ar-t">${tests.map(t=>`<option value="${t.id}" data-title="${t.title}" data-text="${encodeURIComponent(t.text||'')}" data-dur="${t.duration||60}" data-lvl="${t.level||'beginner'}">${t.title}</option>`).join('')}</select></div><button class="ba bs" onclick="aCreateRace()">+ Create Race</button></div><table class="at"><thead><tr><th>Code</th><th>Test</th><th>Status</th><th>Actions</th></tr></thead><tbody>${races.map(r=>`<tr><td><strong style="font-family:monospace;letter-spacing:.1em">${r.code||'?'}</strong></td><td>${r.testTitle||''}</td><td><span class="tag ${r.status==='lobby'?'tgr':r.status==='racing'?'to':'tg'}">${r.status||'?'}</span></td><td style="display:flex;gap:5px">${r.status==='lobby'?`<button class="bs ba" onclick="aStartRace('${r.id}')">🚀 Start</button>`:r.status==='racing'?`<button class="bs bo" onclick="aEndRace('${r.id}')">End</button>`:''}<button class="bs bd" onclick="aDel('races','${r.id}',aRaces)">Del</button></td></tr>`).join('')}</tbody></table>`}
async function aCreateRace(){const sel=$('ar-t');if(!sel||!sel.value){toast('Select a test.');return}const opt=sel.options[sel.selectedIndex];const code=randCode();await db.collection('races').add({code,testId:sel.value,testTitle:opt.dataset.title||opt.text,text:decodeURIComponent(opt.dataset.text||''),time:parseInt(opt.dataset.dur)||60,level:opt.dataset.lvl||'beginner',status:'lobby',createdAt:FV.serverTimestamp()});toast('Race created! Code: '+code);aRaces()}
async function aStartRace(id){await db.collection('races').doc(id).update({status:'racing',startedAt:FV.serverTimestamp()});toast('Race started!');aRaces()}
async function aEndRace(id){await db.collection('races').doc(id).update({status:'done'});aRaces()}
async function aTeams(){const el=$('apc');el.innerHTML='<p style="color:var(--sub)">Loading...</p>';const sn=await db.collection('teams').get();const teams=sn.docs.map(d=>({id:d.id,...d.data()}));el.innerHTML=`<h3 style="margin-bottom:14px">Teams</h3><div class="af"><div><label>Team name</label><input type="text" id="tn" placeholder="e.g. Madrid, Lisbon..."></div><div><label>Color</label><input type="color" id="tc2" value="#f4a623" style="width:56px;height:34px;border:2px solid var(--bg3);border-radius:6px;padding:2px;cursor:pointer"></div><button class="ba bs" onclick="aAddTeam()">+ Add Team</button></div><p style="font-size:.8rem;color:var(--sub);margin-bottom:12px">Teams appear as a dropdown on the sign-in screen so learners can self-select.</p><table class="at"><thead><tr><th>Color</th><th>Name</th><th></th></tr></thead><tbody>${teams.map(t=>`<tr><td><span style="display:inline-block;width:18px;height:18px;border-radius:50%;background:${t.color||'#999'}"></span></td><td><strong>${t.name}</strong></td><td><button class="bs bd" onclick="aDel('teams','${t.id}',aTeams)">Del</button></td></tr>`).join('')}</tbody></table>`}
async function aAddTeam(){const n=($('tn').value||'').trim();const c=$('tc2').value||'#f4a623';if(!n){toast('Name required.');return}await db.collection('teams').add({name:n,color:c,createdAt:FV.serverTimestamp()});toast('Team added!');aTeams();loadTeamsForWelcome()}

// ── INIT ──
showGsTab('beginner',document.querySelector('.gs-tab.b'));
loadTeamsForWelcome();
(function(){const p=new URLSearchParams(location.search);if(p.get('admin')==='backmarket2026'){showView('admin');aTab('tests')}})();
</script>
