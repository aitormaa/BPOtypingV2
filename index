async function joinRace(code){try{const sn=await db.collection('races').where('code','==',code).limit(1).get();if(sn.empty){toast('Race not found.');return}const doc=sn.docs[0];const race={id:doc.id,...doc.data()};if(race.status==='done'){toast('This race already finished.');return}S.raceId=race.id;S.raceData=race;S.rStarted=false;await db.collection('races').doc(race.id).collection('players').doc(S.user.id).set({name:S.user.name,progress:0,wpm:0,done:false});$('rvt').textContent='🏎️ '+race.testTitle;$('lcd').textContent=race.code;$('rl').style.display='block';$('rpod').style.display='none';showView('race');subRace()}catch(e){toast('Error: '+e.message)}}
function subRace(){if(S.rUnsub)S.rUnsub();S.rUnsub=db.collection('races').doc(S.raceId).onSnapshot(sn=>{if(!sn.exists)return;const d=sn.data();S.raceData=d;if(d.status==='racing'&&!S.rStarted){S.rStarted=true;startRaceEng(d)}});if(S.rpUnsub)S.rpUnsub();S.rpUnsub=db.collection('races').doc(S.raceId).collection('players').onSnapshot(sn=>{const players=sn.docs.map(d=>({id:d.id,...d.data()}));$('lplayers').innerHTML=players.map(p=>`<div class="lpl div">👤 ${p.name}</div>`).join('');updRaceHUD(players);if(players.length>0&&players.every(p=>p.done)){showPodium([...players].sort((a,b)=>(a.finishedAt||Infinity)-(b.finishedAt||Infinity)))}})}
function startRaceEng(race){$('rl').style.display='none';S.test={id:race.testId,title:race.testTitle,text:race.text,duration:race.time||60,level:race.level||'beginner'};$('rh').style.display='block';initEngine();showView('test')}
function updRaceHUD(players){const el=$('rhp');if(!el)return;el.innerHTML=[...players].sort((a,b)=>b.progress-a.progress).map(p=>`<div class="rpr"><div class="rpr-n">${p.name===(S.user?.name||'')?'⭐ '+p.name:p.name}</div><div class="rb-w"><div class="rb" style="width:${p.progress||0}%"></div></div><div class="rpr-w">${p.wpm||0}w</div></div>`).join('')}
async function updRaceP(){if(!S.raceId||!S.user)return;const prog=Math.round((S.wI/S.words.length)*100);const el=S.startT?(Date.now()-S.startT)/6e4:0;try{await db.collection('races').doc(S.raceId).collection('players').doc(S.user.id).update({progress:prog,wpm:el>0?Math.round((S.cc/5)/el):0})}catch(e){}}
async function finRaceP(wpm,elapsed){const gm=gmG();if(!gm.badges.includes('racer')){gm.badges.push('racer');gmS(gm);toast('🏅 Badge: 🏎️ Speed Racer!')}const sn=await db.collection('races').doc(S.raceId).collection('players').get();const rank=sn.docs.map(d=>d.data()).filter(p=>p.done).length+1;await db.collection('races').doc(S.raceId).collection('players').doc(S.user.id).update({done:true,wpm,rank,finishedAt:Date.now(),progress:100})}
function showPodium(players){clearInterval(S.tmr);$('hi').onkeydown=null;$('rh').style.display='none';showView('race');$('rl').style.display='none';$('rpod').style.display='block';$('pod').innerHTML=players.slice(0,3).map((p,i)=>`<div class="pc"><div class="pn">${p.name}</div><div class="pw">${p.wpm||0}w</div><div class="pb-p ${['p1','p2','p3'][i]}">${['🥇','🥈','🥉'][i]}</div></div>`).join('');const me=players.find(p=>p.id===S.user.id||p.name===S.user.name);if(me)$('ryr').textContent=`You finished #${me.rank||'?'} with ${me.wpm} WPM!`;if(S.rUnsub){S.rUnsub();S.rUnsub=null}if(S.rpUnsub){S.rpUnsub();S.rpUnsub=null}}
function leaveRace(){clearInterval(S.tmr);$('hi').onkeydown=null;$('rh').style.display='none';if(S.rUnsub){S.rUnsub();S.rUnsub=null}if(S.rpUnsub){S.rpUnsub();S.rpUnsub=null}S.raceId=null;S.rStarted=false;showView('library');renderLib()}
function dlCSV(headers,rows,filename){const csv=[headers.join(','),...rows.map(r=>r.map(v=>'"'+String(v==null?'':v).replace(/"/g,'""')+'"').join(','))].join('\n');const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);a.download=filename+'_'+new Date().toISOString().slice(0,10)+'.csv';a.click();toast('CSV downloaded ✅')}

